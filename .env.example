# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ORDS API Base URL (defaults to the QCM Demo instance)
ORDS_BASE_URL=https://g4b9bc24e36abdb-atpintellinum.adb.us-ashburn-1.oraclecloudapps.com/ords/qcm_demo/quality

# ORDS Authentication (use one of the following)
# Option 1: Basic Auth
ORDS_USERNAME=
ORDS_PASSWORD=

# Option 2: Bearer Token
ORDS_BEARER_TOKEN=

# QCM user context — required for case creation
# userName / loginId are passed in every POST /case payload
QCM_USERNAME=baig.mohammed
QCM_LOGIN_ID=your_ords_login_id
QCM_FACILITY_ID=1
QCM_FACILITY_CODE=DC01

# Server Port (optional, defaults to 3000)
PORT=3000

# Claude model to use (optional)
CLAUDE_MODEL=claude-sonnet-4-6
